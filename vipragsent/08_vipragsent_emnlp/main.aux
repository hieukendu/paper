\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-phenomenon binary macro-F1 across five systems (5 seeds, 95\% CI). ViPragSent{} (dark blue) leads on every phenomenon; the gap is widest for sarcasm, mocking, and implicit sentiment.\relax }}{7}{figure.caption.27}\protected@file@percent }
\newlabel{fig:perphen}{{2}{7}{Per-phenomenon binary macro-F1 across five systems (5 seeds, 95\% CI). \method {} (dark blue) leads on every phenomenon; the gap is widest for sarcasm, mocking, and implicit sentiment.\relax }{figure.caption.27}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Multi-task ablation on the ViPragSent{} dev set. Pragmatic F1 is the macro across the six binary pragmatic phenomena (different backbone from Table\nobreakspace  {}\ref  {tab:main_pragmatic}, hence higher absolute values); ordinary F1 is averaged across the three public Vietnamese sentiment datasets; ECE is the expected calibration error of the pragmatic polarity head, scaled by $10^3$ ($\dag  $). Cost is normalised to the full ViPragSent{} pipeline. Multi-task training is the single largest contributor ($+6.4$); the rationale auxiliary contributes $+3.0$; the ordinary-sentiment auxiliary contributes $+2.7$.\relax }}{7}{table.caption.29}\protected@file@percent }
\newlabel{tab:ablation}{{4}{7}{Multi-task ablation on the \method {} dev set. Pragmatic F1 is the macro across the six binary pragmatic phenomena (different backbone from Table~\ref {tab:main_pragmatic}, hence higher absolute values); ordinary F1 is averaged across the three public Vietnamese sentiment datasets; ECE is the expected calibration error of the pragmatic polarity head, scaled by $10^3$ ($\dag $). Cost is normalised to the full \method {} pipeline. Multi-task training is the single largest contributor ($+6.4$); the rationale auxiliary contributes $+3.0$; the ordinary-sentiment auxiliary contributes $+2.7$.\relax }{table.caption.29}{}}
