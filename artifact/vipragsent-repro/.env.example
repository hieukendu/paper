# Copy to .env and fill manually. Never commit .env.

# Local data roots
DATA_ROOT=D:\vipragsent-repro\data
LOCAL_VISOBERT_EXPORT=D:\hf_cache\exports\visobert_12000_api
HF_HOME=D:\hf_cache\home
HF_DATASETS_CACHE=D:\hf_cache\datasets
HF_HUB_CACHE=D:\hf_cache\hub

# Dataset access
HF_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=

# Azure OpenAI provider for silver annotation and rationales
# Endpoint example: https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
# Deployment names in Azure, not model IDs. Example: gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_LABEL=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_RATIONALE=gpt-4.1-mini
VIPRAGSENT_API_SYSTEM_PREFIX=gpt41_mini

# Safety switches
RUN_MODE=setup_only
ENABLE_NETWORK_DOWNLOAD=true
ENABLE_SOCIAL_CRAWL=false
ENABLE_FINE_TUNING=false
ALLOW_AGENT_SILVER_LABELS=true
REQUIRE_HUMAN_ADJUDICATION=true

# Local hardware profile
LOCAL_GPU_NAME=Quadro P2000
LOCAL_GPU_VRAM_GB=4
LOCAL_TRAINING_ALLOWED=false
